executor {
    queueSize = 500
}

process {
    cpus   = { check_max( 1    * task.attempt, 'cpus'   ) }
    memory = { check_max( 2.GB * task.attempt, 'memory' ) }
    time   = { check_max( 1.h  * task.attempt, 'time'   ) }

    errorStrategy = { task.attempt <= 3 ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    // ────────────────────────────────────────────────────────────────────────
    // Standard nf-core resource tiers.
    //
    // Every process in modules/*.nf and subworkflows/*.nf carries one of these
    // labels. These definitions are kept consistent with conf/stjude_master.config,
    // which overrides them (with the same values) when running with
    // `-profile stjude_master`. Values are intentionally generous for
    // LSF / cluster execution; the original conservative single-machine tuning
    // (custom per-tool labels such as tag_bam, micro_job, etc.) lives in git
    // history.
    // ────────────────────────────────────────────────────────────────────────
    withLabel: process_single {
        cpus   = { 1 }
        memory = { 6.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel: process_low {
        cpus   = { 6     * task.attempt }
        memory = { 24.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel: process_medium {
        cpus   = { 12    * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel: process_high {
        cpus   = { 24    * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }
    withLabel: process_long {
        time   = { 20.h  * task.attempt }
    }
    withLabel: process_high_memory {
        memory = { 200.GB * task.attempt }
    }
    withLabel: error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel: error_retry {
        errorStrategy = 'retry'
        maxRetries    = 3
    }

    // ── Per-process overrides ────────────────────────────────────────────────
    // SQANTI3_QC is very memory-heavy (original tuning: 150 GB). It keeps
    // process_high CPU/time scaling via its label in modules/sqanti3.nf, but
    // memory is raised to 200 GB and doubled on each retry. The stjude_master
    // queue selector routes jobs to the 'large_mem' queue automatically once a
    // task requests more than 512 GB (i.e. from the 3rd attempt: 200 -> 400 -> 800 GB).
    // SQANTI3 ships in its own container (not the default Iso-Seq image).
    withName: 'SQANTI3_QC' {
        memory    = { 200.GB * task.attempt }
        container = 'https://depot.galaxyproject.org/singularity/sqanti3:6.0.1--hdfd78af_0'
    }
    withName: 'SQANTI3_FILTER' {
        container = 'https://depot.galaxyproject.org/singularity/sqanti3:6.0.1--hdfd78af_0'
    }
}
